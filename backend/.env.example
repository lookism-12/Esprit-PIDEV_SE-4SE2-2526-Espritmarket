# ============================================
# EspritMarket Backend Environment Variables
# ============================================
#
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file with real secrets to git!
# Add .env to .gitignore
#
# ============================================

# MongoDB Configuration
# Get connection string from MongoDB Atlas
MONGODB_URI=mongodb+srv://admin:admin@espritmarket.pm6cdbe.mongodb.net/esprit_market?retryWrites=true&w=majority

# JWT Configuration
# Generate a strong secret key (min 32 characters)
# On Linux/Mac: openssl rand -hex 32
JWT_SECRET=ThisIsAStrongSecretKeyForJWT1234567890!!
JWT_EXPIRATION_MS=86400000

# Admin Account
# Should be strong and changed after first deployment
ADMIN_PASSWORD=Admin@1234

# Server Port
SERVER_PORT=8089

# Application Profile (development, staging, production)
SPRING_PROFILES_ACTIVE=development

# Logging Level
LOGGING_LEVEL_ESPRIT_MARKET=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=INFO

# File Upload Configuration
APP_UPLOAD_DIR=uploads/avatars
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB

# ============================================
# Optional: Cloud Deployment
# ============================================

# AWS Configuration (if using AWS)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Azure Configuration (if using Azure)
# AZURE_STORAGE_ACCOUNT_NAME=your-storage-account
# AZURE_STORAGE_ACCOUNT_KEY=your-storage-key

# ============================================
# Optional: External Services
# ============================================

# Email Service (if needed)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# SMS Service (Twilio example)
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# Cloudinary Configuration (Image Storage)
# ============================================
# Sign up free at https://cloudinary.com
# All images are stored in Cloudinary — NOT on the filesystem or in MongoDB.
CLOUDINARY_CLOUD_NAME=dixy33pd6
CLOUDINARY_API_KEY=488217967366142
CLOUDINARY_API_SECRET=your-api-secret-here
